# ---------------------------------------------------------------------------
# PT Management — environment variables
# Copy to .env and fill in. Never commit real secrets.
# ---------------------------------------------------------------------------

# PostgreSQL (Railway provides this in production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptmanagement?schema=public"

# Auth.js (NextAuth v5) — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"

# Base URL of the app (used by Auth.js + Stripe redirects)
NEXTAUTH_URL="http://localhost:3000"

# Stripe (test keys for development)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Google Gemini
GEMINI_API_KEY="..."
