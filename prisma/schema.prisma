// PT Management — Prisma schema
// PostgreSQL. UK market: GBP, Europe/London. UK GDPR-aware data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  TRAINER
  CLIENT
  ADMIN
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED_FREE // cancelled more than 24h before -> no charge
  CANCELLED_LATE // cancelled within 24h -> charged
  NO_SHOW
}

enum AppointmentKind {
  SESSION // a regular training session (requires a dedicated trainer)
  CONSULTATION // an initial consultation before the trainer dedicates the client
}

enum ConsentType {
  HEALTH_DATA // Article 9 special category — requires explicit consent
  MARKETING
  COOKIES
  TERMS
}

enum PaymentMethodType {
  CARD
  BACS_DEBIT // UK Direct Debit
}

enum PaymentMethodStatus {
  PENDING
  ACTIVE
  FAILED
  CANCELLED
}

enum PaymentType {
  SESSION
  PACKAGE
  LATE_CANCEL_FEE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PlanScope {
  DAY
  WEEK
  MONTH
}

enum AiInsightType {
  SCHEDULE_OPT
  CLIENT_SUMMARY
}

enum DataRequestType {
  EXPORT
  ERASURE
}

// Muscle groups an exercise targets (factual taxonomy).
enum MuscleGroup {
  CHEST
  UPPER_BACK
  LATS
  LOWER_BACK
  TRAPS
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  ABS
  OBLIQUES
  GLUTES
  QUADS
  HAMSTRINGS
  CALVES
  ADDUCTORS
  NECK
  FULL_BODY
}

// Equipment an exercise needs.
enum Equipment {
  BARBELL
  DUMBBELL
  KETTLEBELL
  CABLE
  MACHINE
  BODYWEIGHT
  RESISTANCE_BAND
  PLATE
  BENCH
  OTHER
}

// Movement category for grouping/filtering.
enum ExerciseCategory {
  PUSH
  PULL
  LEGS
  CORE
  CARDIO
  FULL_BODY
  MOBILITY
}

// A client's primary training goal, chosen at sign-up.
enum TrainingGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  STRENGTH
  ENDURANCE
  HEALTH // healthier living / wellbeing
  GENERAL // general fitness
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

// ---------------------------------------------------------------------------
// Core identity
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CLIENT)
  name         String
  phone        String?
  goal         TrainingGoal? // client's primary goal, set at sign-up
  locale       String   @default("en") // "en" | "hu"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trainerProfile TrainerProfile?
  clientProfile  ClientProfile?
  consents       Consent[]
  dataRequests   DataRequest[]
  auditLogs      AuditLog[]      @relation("ActorAuditLogs")
}

model TrainerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  headline      String? // short public tagline shown in the directory
  specialties    String[] @default([]) // specialist areas (public)
  qualifications String[] @default([]) // qualifications (public)
  achievements   String[] @default([]) // results / achievements (public)
  city           String? // public location (for local search)
  country        String  @default("GB")
  online         Boolean @default(false) // offers online sessions
  inPerson       Boolean @default(true) // offers in-person sessions
  photoData     Bytes? // profile photo bytes (served via API)
  photoMime     String? // photo mime type, e.g. image/jpeg
  acceptingClients Boolean @default(true) // shown publicly + open to consultations
  timezone      String   @default("Europe/London")
  hourlyRatePence Int    @default(0) // GBP stored in pence
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clients              ClientProfile[]
  availabilityRules    AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  appointments         Appointment[]
  trainingPlans        TrainingPlan[]
  workoutPrograms      WorkoutProgram[]
  nutritionPlans       NutritionPlan[]
  reviews              Review[]
  requestResponses     TrainerRequestResponse[]
}

model ClientProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainerId       String? // the dedicated trainer; null until a trainer dedicates the client
  trainer         TrainerProfile? @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  stripeCustomerId String? @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  healthNotes    HealthNote[]
  appointments   Appointment[]
  creditPacks    CreditPack[]
  paymentMethods PaymentMethod[]
  payments       Payment[]
  trainingPlans  TrainingPlan[]
  workoutPrograms WorkoutProgram[]
  nutritionPlans  NutritionPlan[]
  reviews         Review[]

  @@index([trainerId])
}

// ---------------------------------------------------------------------------
// GDPR / consent / audit
// ---------------------------------------------------------------------------

// Special category (health) data — access-restricted, audited.
model HealthNote {
  id        String   @id @default(cuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Consent {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ConsentType
  version     String // policy/text version the user agreed to
  granted     Boolean
  grantedAt   DateTime?
  withdrawnAt DateTime?
  createdAt   DateTime    @default(now())

  @@index([userId, type])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
  action    String // e.g. HEALTH_NOTE_VIEW, CONSENT_GRANT, DATA_EXPORT, DATA_ERASURE
  entity    String // e.g. HealthNote, Consent, User
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model DataRequest {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        DataRequestType
  status      DataRequestStatus @default(PENDING)
  requestedAt DateTime          @default(now())
  completedAt DateTime?

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Availability & booking
// ---------------------------------------------------------------------------

// Weekly recurring template, split into hourly slots.
model AvailabilityRule {
  id        String   @id @default(cuid())
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0 = Sunday ... 6 = Saturday
  startHour Int // 0-23 inclusive
  endHour   Int // exclusive end (e.g. 12 means last bookable slot starts 11:00)
  createdAt DateTime @default(now())

  @@index([trainerId])
}

// One-off block (holiday) or extra availability on a specific date.
model AvailabilityException {
  id         String   @id @default(cuid())
  trainerId  String
  trainer    TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  date       DateTime // calendar date (midnight UTC marker)
  startHour  Int
  endHour    Int
  isBlocked  Boolean  @default(true) // true = unavailable, false = extra availability
  createdAt  DateTime @default(now())

  @@index([trainerId, date])
}

model Appointment {
  id          String            @id @default(cuid())
  trainerId   String
  trainer     TrainerProfile    @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId    String
  client      ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  startAt     DateTime // stored in UTC
  endAt       DateTime // stored in UTC
  status      AppointmentStatus @default(BOOKED)
  kind        AppointmentKind   @default(SESSION)
  cancelledAt DateTime?
  creditId    String?
  credit      SessionCredit?    @relation(fields: [creditId], references: [id], onDelete: SetNull)
  paymentId   String?
  payment     Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([trainerId, startAt]) // prevents double-booking a slot
  @@index([clientId])
}

// Public client review of a trainer. One review per client per trainer
// (upserted), gated server-side to clients with a real relationship.
model Review {
  id        String         @id @default(cuid())
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([trainerId, clientId])
  @@index([trainerId])
}

// A prospective client's public "find me a trainer" request (reverse
// marketplace). Trainers browse open requests and reach out; each can mark
// that they responded. consentAt evidences GDPR consent given at submission.
model TrainerRequest {
  id        String                   @id @default(cuid())
  name      String
  email     String
  goal      String
  city      String?
  online    Boolean                  @default(false)
  open      Boolean                  @default(true)
  consentAt DateTime                 @default(now())
  createdAt DateTime                 @default(now())
  responses TrainerRequestResponse[]

  @@index([open, createdAt])
}

model TrainerRequestResponse {
  id        String         @id @default(cuid())
  requestId String
  request   TrainerRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([requestId, trainerId])
  @@index([trainerId])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model CreditPack {
  id            String   @id @default(cuid())
  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name          String // e.g. "12 sessions"
  totalSessions Int
  remaining     Int
  purchasedAt   DateTime @default(now())
  expiresAt     DateTime?
  paymentId     String?
  payment       Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  credits SessionCredit[]

  @@index([clientId])
}

// A single consumable credit drawn from a pack.
model SessionCredit {
  id        String   @id @default(cuid())
  packId    String
  pack      CreditPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  appointments Appointment[]

  @@index([packId])
}

model PaymentMethod {
  id                  String              @id @default(cuid())
  clientId            String
  client              ClientProfile       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stripePaymentMethodId String            @unique
  type                PaymentMethodType
  status              PaymentMethodStatus @default(PENDING)
  mandateReference    String? // Bacs Direct Debit mandate id
  brand               String? // card brand / bank name
  last4               String?
  isDefault           Boolean             @default(false)
  createdAt           DateTime            @default(now())

  @@index([clientId])
}

model Payment {
  id                    String        @id @default(cuid())
  clientId              String
  client                ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amountPence           Int
  currency              String        @default("gbp")
  type                  PaymentType
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  appointments Appointment[]
  creditPacks  CreditPack[]

  @@index([clientId])
}

// ---------------------------------------------------------------------------
// Planning & AI
// ---------------------------------------------------------------------------

model TrainingPlan {
  id        String    @id @default(cuid())
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String?
  client    ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  scope     PlanScope
  startDate DateTime
  endDate   DateTime
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  items PlanItem[]

  @@index([trainerId])
  @@index([clientId])
}

model PlanItem {
  id        String   @id @default(cuid())
  planId    String
  plan      TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  position  Int      @default(0)
  content   String
  notes     String?
  createdAt DateTime @default(now())

  @@index([planId])
}

model AiInsight {
  id        String        @id @default(cuid())
  type      AiInsightType
  targetId  String // trainerId for SCHEDULE_OPT, clientId for CLIENT_SUMMARY
  content   String
  createdAt DateTime      @default(now())

  @@index([type, targetId])
}

// Structured training program assigned to a client. The day/exercise structure
// is stored as JSON (loaded wholesale; not queried field-by-field).
model WorkoutProgram {
  id        String   @id @default(cuid())
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  data      Json // { notes, days: [{ label, exercises: [{ name, sets, reps, notes }] }] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([trainerId])
}

// Structured nutrition / meal plan assigned to a client (JSON structure).
model NutritionPlan {
  id        String   @id @default(cuid())
  trainerId String
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String
  client    ClientProfile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  data      Json // { notes, meals: [{ name, items: [{ food, qty, kcal, protein, carbs, fat }] }] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([trainerId])
}

// Processed Stripe webhook events — used to make webhook handling idempotent.
model WebhookEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}

// Fixed-window rate limiting (e.g. login/register). Survives restarts and is
// shared across instances, unlike the in-memory limiter used for AI endpoints.
model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime
}

// Key-value app settings (e.g. integration credentials configured by an admin).
// Secret values are stored encrypted (AES-256-GCM); `encrypted` marks those.
model Setting {
  key       String   @id
  value     String
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Global exercise library. Holds factual data (which muscles an exercise
// works, equipment) plus our own short cues — no third-party text or media.
model Exercise {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  category        ExerciseCategory
  equipment       Equipment
  primaryMuscles  MuscleGroup[]    @default([])
  secondaryMuscles MuscleGroup[]   @default([])
  cues            String[]         @default([]) // our own short how-to cues
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([category])
}
